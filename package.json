{
  "name": "fuel-scraper",
  "version": "1.0.0",
  "description": "Web scraper para extraer saldos de combustible de estaciones de servicio",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "bot": "npm run build && node dist/index.js",
    "scrape": "npm run build && node dist/scraper.js",
    "bot-legacy": "npm run build && node dist/telegram-bot.js",
    "bot-webhook-legacy": "npm run build && node dist/telegram-bot-webhook.js",
    "bot-production-legacy": "npm run build && node dist/production-bot.js",
    "test-bot": "npm run build && node dist/test-bot.js",
    "check-instances": "npm run build && node dist/check-instances.js",
    "debug-scraper": "npm run build && node dist/debug-scraper.js",
    "verify-real-data": "npm run build && node dist/verify-real-data.js",
    "dev": "ts-node src/scraper.ts",
    "dev-bot": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rimraf dist output"
  },
  "keywords": [
    "scraper",
    "fuel",
    "combustible"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.1.2",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
